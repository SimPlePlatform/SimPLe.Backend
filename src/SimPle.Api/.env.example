# Copy this to .env and fill in real values, or run:
#   powershell -ExecutionPolicy Bypass -File scripts/Initialize-AuthEnvironment.ps1
# Never commit .env.

# Database
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=simple_auth_dev;Username=simple_auth;Password=REPLACE_WITH_LOCAL_DATABASE_PASSWORD
POSTGRES_DB=simple_auth_dev
POSTGRES_USER=simple_auth
POSTGRES_PASSWORD=REPLACE_WITH_LOCAL_DATABASE_PASSWORD

# JWT signing key (at least 32 random chars)
Jwt__SecretKey=REPLACE_WITH_A_LONG_RANDOM_SIGNING_KEY

# reCAPTCHA
Recaptcha__SecretKey=REPLACE_WITH_RECAPTCHA_V2_SECRET_KEY

# Email
Email__From=REPLACE_WITH_YOUR_SENDER_EMAIL
Email__Username=REPLACE_WITH_YOUR_SMTP_USERNAME
Email__Password=REPLACE_WITH_YOUR_SMTP_PASSWORD

# Google OAuth
Google__ClientId=REPLACE_WITH_GOOGLE_OAUTH_CLIENT_ID

# AWS S3 profile media. Use a private bucket; do not put AWS credentials in frontend config.
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=REPLACE_WITH_PRIVATE_PROFILE_MEDIA_BUCKET
AWS_S3_PROFILE_PREFIX=profile-assets
AWS_S3_UPLOAD_URL_EXPIRY_MINUTES=10
AWS_S3_READ_URL_EXPIRY_MINUTES=15
