# Copy this to .env and fill in real values, or run:
#   powershell -ExecutionPolicy Bypass -File scripts/Initialize-AuthEnvironment.ps1
# Never commit .env.

# ─── Database (also read by compose.auth.yml) ─────────────────────────────────
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=simple_auth_dev;Username=simple_auth;Password=REPLACE_WITH_LOCAL_DATABASE_PASSWORD
POSTGRES_DB=simple_auth_dev
POSTGRES_USER=simple_auth
POSTGRES_PASSWORD=REPLACE_WITH_LOCAL_DATABASE_PASSWORD

# ─── JWT signing key (≥32 random chars) ───────────────────────────────────────
Jwt__SecretKey=REPLACE_WITH_A_LONG_RANDOM_SIGNING_KEY

# ─── reCAPTCHA — get the SECRET KEY from google.com/recaptcha/admin ───────────
Recaptcha__SecretKey=REPLACE_WITH_RECAPTCHA_V2_SECRET_KEY

# ─── Email — Gmail: myaccount.google.com → Security → App passwords ───────────
Email__From=REPLACE_WITH_YOUR_SENDER_EMAIL
Email__Username=REPLACE_WITH_YOUR_GMAIL_ADDRESS
Email__Password=REPLACE_WITH_YOUR_APP_PASSWORD

# ─── Google OAuth — console.cloud.google.com → APIs & Services → Credentials ──
Google__ClientId=REPLACE_WITH_GOOGLE_OAUTH_CLIENT_ID

# ─── AWS S3 — avatar and banner image uploads ─────────────────────────────────
# How to get these:
#   1. Sign in at console.aws.amazon.com
#   2. Create an S3 bucket (e.g. simpleplatform-media). Unblock public access for the bucket.
#   3. IAM → Users → Create user → Attach "AmazonS3FullAccess" (or a scoped put/delete policy).
#   4. Security credentials → Create access key → "Application outside AWS" → copy both values.
#   5. Paste them below. The Secret Access Key is shown only once.
AWS__AccessKeyId=REPLACE_WITH_AWS_ACCESS_KEY_ID
AWS__SecretAccessKey=REPLACE_WITH_AWS_SECRET_ACCESS_KEY
AWS__Region=us-east-1
AWS__S3BucketName=REPLACE_WITH_S3_BUCKET_NAME
# Optional: CloudFront or custom URL prefix (omit to use default S3 URLs)
# AWS__S3PublicUrlBase=https://cdn.example.com
