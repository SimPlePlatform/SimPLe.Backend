{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigin": "http://localhost:3000"
  },
  "ConnectionStrings": {
    "DefaultConnection": "See appsettings.Development.json or environment variables"
  },
  "Jwt": {
    "Issuer": "SimPle",
    "Audience": "SimPle",
    "ExpiryMinutes": 15,
    "SecretKey": "CONFIGURE_WITH_USER_SECRETS_OR_ENVIRONMENT"
  },
  "Auth": {
    "RefreshTokenExpiryDays": 7,
    "MaxFailedLoginAttempts": 10,
    "LockoutDurationMinutes": 15
  },
  "Recaptcha": {
    "SecretKey": "CONFIGURE_VIA_ENVIRONMENT",
    "VerificationUrl": "https://www.google.com/recaptcha/api/siteverify"
  },
  "Email": {
    "FromName": "SimPle",
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": 587,
    "AppUrl": "http://localhost:3000"
  },
  "Google": {
    "ClientId": "CONFIGURE_VIA_ENVIRONMENT"
  },
  "AWS": {
    "Region": "AWS_REGION",
    "S3BucketName": "AWS_S3_BUCKET_NAME",
    "S3ProfilePrefix": "AWS_S3_PROFILE_PREFIX",
    "S3UploadUrlExpiryMinutes": 10,
    "S3ReadUrlExpiryMinutes": 15
  }
}
